# Local development only. Copy to .env and replace every value locally.
POSTGRES_DB=zumingtalk
POSTGRES_USER=zumingtalk_dev
POSTGRES_PASSWORD=replace-with-a-local-development-password
ZUMINGTALK_ADMIN_API_KEY=replace-with-a-random-admin-key
Alipay__AppId=replace-with-sandbox-app-id
Alipay__SellerId=replace-with-sandbox-seller-id
Alipay__MerchantPrivateKeyPath=C:\replace\with\local\merchant-private-key.pem
Alipay__AlipayPublicKeyPath=C:\replace\with\local\alipay-public-key.pem
Alipay__NotifyUrl=https://replace-with-public-test-host/api/payments/alipay/notify
Alipay__ReturnUrl=https://replace-with-public-test-host/payments/alipay/return
